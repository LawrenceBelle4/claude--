                            "type": "custom_code",
                            "id": "F+CtexH*G|eRp(^mqmDu",
                            "fields": {
                              "CODE": "gPrev=gState; gFrm=0;\nif(gState==0){gIdleSt=0; gIdleT=millis();}\nelse{gTrans=(gState==1)?(int)gIdleSt:0; gIdleSt=0;}\nif(gState==3){digitalWrite(3,HIGH);delay(100);digitalWrite(3,LOW);delay(100);digitalWrite(3,HIGH);delay(100);digitalWrite(3,LOW);}\nif(gState==4){for(int i=0;i<4;i++){digitalWrite(3,HIGH);delay(40);digitalWrite(3,LOW);delay(40);}}"
                            }
                          }
                        }
                      },
                      "next": {
                        "block": {
                          "type": "controls_if",
                          "id": "T3ATGXu7P`,lXinNgnh0",
                          "inputs": {
