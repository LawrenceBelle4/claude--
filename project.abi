                      "block": {
                        "type": "custom_code",
                        "id": "cP+(!9k!i_h4OOkK@.E~",
                        "fields": {
                          "CODE": "gBtn=0; delay(40);\nif(digitalRead(2)==LOW){\n  unsigned long t0=millis();\n  while(digitalRead(2)==LOW && millis()-t0<1200) delay(20);\n  if(millis()-t0>700){gMut=!gMut; Serial.println(gMut?\"muted\":\"unmuted\");}\n  else{Serial.println(\"btn\"); if(!gMut) tone(4,1000,50);}\n}"
                        }
                      }
                    }
                  },
