                    "id": "hv6Lz5V,qax/3.mm2?ID",
                    "fields": {
                      "CODE": "String s = Serial.readStringUntil('\\n'); s.trim();\nif(s==\"idle\") gState=0;\nelse if(s==\"thinking\") gState=1;\nelse if(s==\"coding\") gState=2;\nelse if(s==\"done\") gState=3;\nelse if(s==\"permission\") gState=4;"
                    }
                  }
                }
